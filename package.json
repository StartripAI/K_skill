{
  "name": "kskill",
  "version": "0.1.0",
  "description": "本地语音人格工作台 / Local voice + persona workbench for chats, characters, relationship memory, Crush Coach, and Life Mentor packs.",
  "type": "module",
  "main": "./dist/packages/core/src/index.js",
  "types": "./dist/packages/core/src/index.d.ts",
  "bin": {
    "kskill": "dist/packages/cli/src/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/packages/core/src/index.d.ts",
      "import": "./dist/packages/core/src/index.js"
    },
    "./core": {
      "types": "./dist/packages/core/src/index.d.ts",
      "import": "./dist/packages/core/src/index.js"
    },
    "./importers": {
      "types": "./dist/packages/importers/src/index.d.ts",
      "import": "./dist/packages/importers/src/index.js"
    },
    "./pursuit": {
      "types": "./dist/packages/pursuit/src/index.d.ts",
      "import": "./dist/packages/pursuit/src/index.js"
    },
    "./distiller": {
      "types": "./dist/packages/distiller/src/index.d.ts",
      "import": "./dist/packages/distiller/src/index.js"
    },
    "./exporters": {
      "types": "./dist/packages/exporters/src/index.d.ts",
      "import": "./dist/packages/exporters/src/index.js"
    },
    "./server": {
      "types": "./dist/packages/server/src/index.d.ts",
      "import": "./dist/packages/server/src/index.js"
    },
    "./vault": {
      "types": "./dist/packages/vault/src/index.d.ts",
      "import": "./dist/packages/vault/src/index.js"
    },
    "./voice": {
      "types": "./dist/packages/voice/src/index.d.ts",
      "import": "./dist/packages/voice/src/index.js"
    },
    "./media": {
      "types": "./dist/packages/media/src/index.d.ts",
      "import": "./dist/packages/media/src/index.js"
    },
    "./pack-io": {
      "types": "./dist/packages/pack-io/src/index.d.ts",
      "import": "./dist/packages/pack-io/src/index.js"
    },
    "./contracts": {
      "types": "./dist/packages/contracts/src/index.d.ts",
      "import": "./dist/packages/contracts/src/index.js"
    }
  },
  "files": [
    "dist",
    "dist-web",
    "README.md",
    "README_EN.md",
    "README_JA.md",
    "README_KO.md",
    "README_ES.md",
    "LICENSE",
    "docs",
    "assets",
    "examples"
  ],
  "scripts": {
    "build": "node scripts/clean-build.mjs && tsc -p tsconfig.json --noEmit && vite build --config apps/web/vite.config.ts && tsc -p tsconfig.build.json && node scripts/postbuild.mjs",
    "dev": "vite --host 127.0.0.1 --config apps/web/vite.config.ts",
    "serve": "vite --host 127.0.0.1 --config apps/web/vite.config.ts",
    "cli": "tsx packages/cli/src/index.ts",
    "lint": "tsc -p tsconfig.json --noEmit && node scripts/check-i18n.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "check:readme": "node scripts/check-readme.mjs",
    "check:exports": "node scripts/check-exports.mjs",
    "check:media-fixtures": "node scripts/check-media-fixtures.mjs",
    "test:e2e": "playwright test",
    "smoke": "node scripts/smoke.mjs",
    "smoke:cli-api": "node scripts/smoke-cli-api.mjs",
    "score:release": "node scripts/score-release.mjs",
    "verify": "npm run lint && npm test && npm run build && npm run check:exports && npm run check:media-fixtures && npm run check:readme && npm run test:e2e && npm run smoke && npm run smoke:cli-api && npm run score:release && node scripts/clean-release-artifacts.mjs && npm pack --dry-run"
  },
  "keywords": [
    "agent-skills",
    "persona",
    "sillytavern",
    "prompt-engineering",
    "character-card",
    "relationship-memory",
    "crush-coach"
  ],
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.2",
    "@playwright/test": "^1.60.0",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.1.6",
    "better-sqlite3": "^12.10.0",
    "commander": "^14.0.2",
    "csv-parse": "^6.2.1",
    "fflate": "^0.8.2",
    "hono": "^4.12.18",
    "lucide-react": "^0.561.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "vite": "^7.2.7",
    "yaml": "^2.8.2",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  }
}
